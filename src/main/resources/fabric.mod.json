	"entrypoints": {
		"main": [
			"com.enviouse.RaffleTracker"
		],
		"client": [
			"com.enviouse.raffletracker.client.RaffleTrackerClient"
		]
	},
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1",
		"java": ">=25",
		"fabric-api": "*"
