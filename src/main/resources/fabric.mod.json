	"authors": [
		"enviouse"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/enviouse/RaffleTracker"
	},
	"license": "CC0-1.0",
	"icon": "assets/raffletracker/icon.png",
